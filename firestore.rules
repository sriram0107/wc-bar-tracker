rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Bar catalog is read/written only via Firebase Admin (Next.js API + scripts).
    // Deny all direct client SDK access to prevent scraping and unauthorized edits.
    match /bars/{barId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
