# ─── Firebase Admin (server-only — never prefix with NEXT_PUBLIC_) ───
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key from the JSON file; keep quotes and \n escapes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Mapbox (client — safe to expose in browser) ───
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ─── Unique visitors: firebase | vercel | both (default firebase) ───
# firebase = Firestore + anonymous cookie via POST /api/visit
# vercel   = Vercel Web Analytics dashboard (enable Analytics in Vercel project settings)
# both     = use Firestore counts and Vercel Analytics
NEXT_PUBLIC_VISITOR_TRACKING=firebase

# Optional: protect GET /api/stats/visitors with header x-stats-secret
# STATS_READ_SECRET=your-random-secret

# ─── Plausible Analytics (optional — product events, not unique visitors) ───
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com

# ─── Waitlist CTA (optional) ───
# Google Form "viewform" URL — opens in a new tab from the header button
NEXT_PUBLIC_WAITLIST_FORM_URL=https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform

# ─── Error monitoring (optional) ───
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
